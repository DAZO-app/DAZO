@startuml

entity users {
  +id : uuid
  name
  email
}

entity roles {
  +id
  name
}

entity role_user {
  user_id
  role_id
}

entity circles {
  +id : uuid
  name
  parent_id
}

entity circle_user {
  circle_id
  user_id
  role_in_circle
}

entity decisions {
  +id : uuid
  title
  content
  status
  circle_id
  author_id
}

entity decision_user {
  decision_id
  user_id
  role
}

entity feedbacks {
  +id : uuid
  type
  content
  status
  decision_id
  author_id
}

entity votes {
  +id : uuid
  value
  decision_id
  user_id
}

users ||--o{ role_user
roles ||--o{ role_user

users ||--o{ circle_user
circles ||--o{ circle_user

circles ||--o{ decisions
users ||--o{ decisions : author

decisions ||--o{ feedbacks
users ||--o{ feedbacks : author

decisions ||--o{ votes
users ||--o{ votes

decisions ||--o{ decision_user
users ||--o{ decision_user

@enduml
